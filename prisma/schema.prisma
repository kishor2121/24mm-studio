generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photographer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  email     String   @unique
  password  String
  images     Image[]
  videos     Video[]
  notifications Notification[]
}

model Image {
  id            Int        @id @default(autoincrement())
  url           String
  // optional tag/section to control where the image is displayed (e.g. "home" or "gallery")
  section       String?    @default("gallery")
  // service type (Wedding, Engagement, Pre-Wedding, etc.)
  service       String?    @default("Wedding")
  // event name/couple name (e.g., "Arjun & Jasmeet", "Manjunath & Ramya")
  eventName     String?
  photographer  Photographer @relation(fields: [photographerId], references: [id])
  photographerId Int
  createdAt     DateTime   @default(now())
  reviews       Review[]
}

model Video {
  id            Int        @id @default(autoincrement())
  url           String
  // service type (Wedding, Engagement, etc.)
  service       String?    @default("Wedding")
  // event name/couple name
  eventName     String?
  photographer  Photographer @relation(fields: [photographerId], references: [id])
  photographerId Int
  createdAt     DateTime   @default(now())
  reviews       Review[]
}

model Review {
  id            Int        @id @default(autoincrement())
  content       String
  name          String?    @default("Anonymous")
  rating        Int        @default(5)
  imageId      Int?
  videoId      Int?
  createdAt     DateTime   @default(now())
  image         Image?     @relation(fields: [imageId], references: [id])
  video         Video?     @relation(fields: [videoId], references: [id])
}

model Notification {
  id              Int       @id @default(autoincrement())
  title           String
  description     String
  imageUrl        String
  icon            String?   @default("📢")
  expiresAt       DateTime?
  photographer    Photographer @relation(fields: [photographerId], references: [id])
  photographerId  Int
  createdAt       DateTime  @default(now())
}
